PROJECT_TYPE="shell"
PROJECT_NAME="vj-archive"
CLAUDE_TIMEOUT_MINUTES=10
PRIMARY_MODEL="sonnet"
MAX_CALLS_PER_HOUR=40
QG_GO_BUILD="false"
QG_GO_TEST="false"
QG_GO_VET="false"
CASCADE_ENABLED="true"
AUTONOMY_LEVEL=1
MARATHON_MODE="true"
MARATHON_DURATION_HOURS="4"
RALPH_SESSION_BUDGET="30"
CB_SAME_ERROR_THRESHOLD="5"
CB_COOLDOWN_MINUTES="15"
CB_AUTO_RESET="true"
ALLOWED_TOOLS="Write,Read,Edit,Grep,Glob,Bash(shellcheck *),Bash(git *),Bash(make *),Bash(bash *)"
